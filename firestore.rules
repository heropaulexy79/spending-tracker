rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core Privacy Rule: Users can ONLY access their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Protect the logs subcollection
      match /logs/{logId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Protect the urges subcollection
      match /urges/{urgeId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
